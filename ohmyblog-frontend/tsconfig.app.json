{
  "extends": "./node_modules/@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"],
      // 仅导入后端类型（不打包 runtime）
      "@server/app": ["../ohmyblog-backend/src/app.d.ts"],
      // 前后端共享同一份 Elysia 类型，避免版本不一致报错
      "elysia": ["../ohmyblog-backend/node_modules/elysia"],
      // 后端 DTO 类型（例如 TRegisterDTO / TLoginDTO）
      "@server/dtos/*": ["../ohmyblog-backend/src/dtos/*"],
      // 后端 db/constants 下的零依赖共享常量（前后端复用枚举字面量）
      "@server/db/constants/*": ["../ohmyblog-backend/db/constants/*"],
      // 后端数据库表定义（用于推断类型）
      "@server/db/table/*": ["../ohmyblog-backend/db/table/*"],
      // TypeBox runtime 校验（复用后端依赖）
      "@sinclair/typebox": [
        "../ohmyblog-backend/node_modules/@sinclair/typebox"
      ],
      "@sinclair/typebox/*": [
        "../ohmyblog-backend/node_modules/@sinclair/typebox/*"
      ]
    }
  }
}

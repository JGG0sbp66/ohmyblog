{
	"name": "ohmyblog-backend",
	"version": "1.0.50",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev": "bun run --watch src/index.ts",
		"start": "NODE_ENV=production bun run src/index.ts",
		"debug": "bun --inspect-wait --watch src/index.ts",
		"email": "email dev --dir src/templates",
		"db:push": "drizzle-kit push --config=db/drizzle.config.ts",
		"db:studio": "drizzle-kit studio --config=db/drizzle.config.ts",
		"db:gen": "drizzle-kit generate --config=db/drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config=db/drizzle.config.ts",
		"lint": "biome lint .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"build:win": "bun run scripts/build.ts win",
		"build:linux": "bun run scripts/build.ts linux",
		"build:linux-musl": "bun run scripts/build.ts linux-musl",
		"build:mac": "bun run scripts/build.ts mac",
		"docker": "docker build --build-arg GIT_COMMIT=$(git rev-parse --short HEAD) -t ohmyblog-backend -f scripts/Dockerfile ."
	},
	"dependencies": {
		"@elysiajs/jwt": "^1.4.1",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/static": "^1.4.9",
		"@napi-rs/image": "^1.12.0",
		"@paralleldrive/cuid2": "^3.3.0",
		"@react-email/components": "^1.0.12",
		"consola": "^3.4.2",
		"culori": "^4.0.2",
		"drizzle-orm": "^0.45.2",
		"elysia": "^1.4.28",
		"nodemailer": "^8.0.5",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@react-email/ui": "6.0.1",
		"@types/node": "^25.6.0",
		"@types/nodemailer": "^7.0.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"bun-types": "latest",
		"drizzle-kit": "^0.31.10",
		"react-email": "^6.0.1"
	},
	"module": "src/index.js"
}
